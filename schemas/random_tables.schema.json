{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIGM V1 Random Tables",
  "type": "object",
  "required": ["random_tables"],
  "properties": {
    "random_tables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "entries"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "visibility": {
            "type": "string",
            "enum": ["known", "hinted", "hidden", "gm"],
            "default": "known"
          },
          "entries": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["result"],
              "properties": {
                "result": {
                  "type": "string",
                  "minLength": 1
                },
                "weight": {
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "default": 1
                },
                "tags": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
