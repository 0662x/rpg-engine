{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RPG Engine Content Delta",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "intent": {"type": "string", "minLength": 1},
    "event_type": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "user_text": {"type": "string", "minLength": 1},
    "game_time": {"type": "string", "minLength": 1},
    "changed": {"type": "boolean"},
    "turn_id": {"type": "string", "pattern": "^turn:(seed|[0-9]{6})$"},
    "updated_turn_id": {"type": "string", "pattern": "^turn:(seed|[0-9]{6})$"},
    "expected_turn_id": {"type": "string", "pattern": "^turn:(seed|[0-9]{6})$"},
    "command_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"},
    "event_id": {"type": "string"},
    "events": {"type": "array"},
    "meta": {"type": "object"},
    "upsert_entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "name", "summary"]
      }
    },
    "upsert_routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from_location_id", "to_location_id", "travel_minutes"]
      }
    },
    "upsert_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement"]
      }
    },
    "upsert_world_settings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "summary"]
      }
    }
  }
}
