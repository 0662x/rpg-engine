{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIGM V1 Campaign Smoke Tests",
  "type": "object",
  "required": ["smoke_tests"],
  "properties": {
    "smoke_tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "capabilities"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["start_turn", "query", "preview", "validate_delta", "random_table"]
          },
          "capabilities": {
            "$ref": "capabilities.schema.json"
          },
          "user_text": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": ["auto", "query", "action", "maintenance"]
          },
          "submode": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": ["scene", "entity", "context"]
          },
          "query_text": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "options": {
            "type": "object"
          },
          "delta": {
            "type": "object"
          },
          "table": {
            "type": "string"
          },
          "contains": {
            "type": "string"
          }
        }
      }
    }
  }
}
